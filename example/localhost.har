height=\"19\" viewBox=\"0 0 32 19\" fill=\"none\"><rect x=\"-0.75\" y=\"0.75\" width=\"30.5\" height=\"17.5\" rx=\"8.75\" transform=\"matrix(-1 0 0 1 30.5 0)\" stroke=\"#01BE4A\" stroke-width=\"1.5\"></rect><path d=\"M21 8.75C21.4142 8.75 21.75 9.08579 21.75 9.5C21.75 9.91421 21.4142 10.25 21 10.25V8.75ZM10.4697 10.0303C10.1768 9.73744 10.1768 9.26256 10.4697 8.96967L15.2426 4.1967C15.5355 3.90381 16.0104 3.90381 16.3033 4.1967C16.5962 4.48959 16.5962 4.96447 16.3033 5.25736L12.0607 9.5L16.3033 13.7426C16.5962 14.0355 16.5962 14.5104 16.3033 14.8033C16.0104 15.0962 15.5355 15.0962 15.2426 14.8033L10.4697 10.0303ZM21 9.5V10.25L11 10.25V9.5V8.75L21 8.75V9.5Z\" fill=\"#01BE4A\"></path></svg>\r\n            </span>\r\n            <span class=\"psy-back-text\">Zobacz więcej</span>\r\n        </a>\r\n    </div>\r\n\r\n    <article class=\"psy-profile-card\">\r\n\r\n        <header class=\"psy-card-header\">\r\n            <div class=\"psy-card-photo\">\r\n                                    <img width=\"761\" height=\"1024\" src=\"https://media.niepodzielni.com/wp-content/uploads/20260330170450/Profilowe-761x1024.jpg\" class=\"attachment-large size-large\" alt=\"filip dudzicz\" decoding=\"async\" loading=\"lazy\" />\r\n                            </div>\r\n\r\n            <div class=\"psy-card-main-info\">\r\n                <h1 class='psy-name-h1'>Filip Dudzicz</h1>\r\n\r\n                <div class=\"psy-tag-profession\">Psycholog</div>\r\n\r\n                <div class=\"psy-specializations-row\">\r\n                    <div class=\"specialist-attributes\">\r\n            <p class=\"attribute-tag\">Psycholog</p>\r\n    </div>\r\n\r\n                </div>\r\n\r\n                <div class=\"psy-languages-row\">\r\n                    <div class=\"jezyki_contener\">\r\n    <div class=\"jezyki_lewa_czesc\">\r\n        <span class=\"takie_jezyki tekst_duzy\">Języki: &nbsp;</span>\r\n    </div>\r\n    <div class=\"jezyki_prawa_czesc\">\r\n                    <span class=\"jeden_jezyk\" style=\"display:inline-flex; align-items:center; margin-right:15px;\">\r\n                                    <span class=\"fi fi-pl\" style=\"margin-right:8px; border-radius:2px;\"></span>\r\n                                <div class=\"opis_jezyka_przy_obrazie\">Polski</div>\r\n            </span>\r\n            </div>\r\n</div>\r\n\r\n                </div>\r\n            </div>\r\n\r\n            <div class=\"psy-header-meta\">\r\n                <div class=\"psy-status-online\">\r\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><rect x=\"2\" y=\"3\" width=\"20\" height=\"14\" rx=\"2\" ry=\"2\"/><line x1=\"8\" y1=\"21\" x2=\"16\" y2=\"21\"/><line x1=\"12\" y1=\"17\" x2=\"12\" y2=\"21\"/></svg> Online\r\n                </div>\r\n                <div class=\"psy-header-price\">\r\n                    <span class=\"dynamic-rate-price\">135 zł</span><span class=\"dynamic-rate-unit\"> / 50 min</span>\r\n                </div>\r\n                                                <div class=\"psy-header-termin\">\r\n                    Najbliższy termin: <span class=\"bookero-date-value\">15 kwietnia 2026</span>\r\n                </div>\r\n                            </div>\r\n        </header>\r\n\r\n        <div id=\"doswiadczenie\" class=\"psy-tab-content is-active\" style=\"display: block;\">\r\n            <h4>O mnie</h4>\r\n            <div class=\"psy-bio-text\">\r\n                <div class=\"sdesc-wrapper\" data-sdesc-container>\r\n    <div class=\"sdesc-content-wrapper\">\r\n        <div class=\"sdesc-short is-visible\">\r\n            Dzień dobry, nazywam się Filip Dudzicz i jestem psychologiem. Moje doświadczenie obejmuje zarówno wsparcie w obszarze zdrowia psychicznego, jak i rozwój zawodowy. Pomagam osobom, które mierzą się ze stresem, wypaleniem zawodowym, trudnościami emocjonalnymi oraz chcą lepiej zrozumieć siebie i swoje potrzeby. Podczas mojej drogi zawodowej zdobywałem doświadczenie w pracy klinicznej, m.in. w Wojewódzkim Szpitalu Psychiatrycznym w Gdańsku, gdzie przeprowadzałem diagnozy...\r\n            <button type=\"button\" class=\"sdesc-toggle-btn sdesc-show-more\">Pokaż więcej</button>\r\n        </div>\r\n        <div class=\"sdesc-full\">\r\n            Dzień dobry, nazywam się Filip Dudzicz i jestem psychologiem.\r\nMoje doświadczenie obejmuje zarówno wsparcie w obszarze zdrowia psychicznego, jak i rozwój zawodowy. Pomagam osobom, które mierzą się ze stresem, wypaleniem zawodowym, trudnościami emocjonalnymi oraz chcą lepiej zrozumieć siebie i swoje potrzeby.\r\n\r\nPodczas mojej drogi zawodowej zdobywałem doświadczenie w pracy klinicznej, m.in. w Wojewódzkim Szpitalu Psychiatrycznym w Gdańsku, gdzie przeprowadzałem diagnozy i wspierałem pacjentów w procesie leczenia. Prowadziłem także warsztaty psychoedukacyjne oraz indywidualne konsultacje psychologiczne, koncentrując się na budowaniu dobrostanu psychicznego i rozwoju osobistym.\r\n\r\nObecnie pracuje w nurcie Terapii Skoncentrowanej na Rozwiązaniach, koncentrując się na budowaniu dobrostanu psychicznego i praktycznych sposobach radzenia sobie z trudnościami. W pracy stawiam na indywidualne podejście, zrozumienie i skuteczne wsparcie.\r\n\r\nNiezależnie od tego, czy potrzebujesz wsparcia w obszarze emocji, stresu, relacji czy rozwoju zawodowego – chętnie pomogę.\r\n            <button type=\"button\" class=\"sdesc-toggle-btn sdesc-collapse\">Zwiń</button>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n            </div>\r\n\r\n            <h4>Obszary pomocy</h4>\r\n            <div class=\"psy-help-tags\">\r\n                <div class=\"help-areas-list\" data-help-areas-container>\r\n            <span class=\"help-area-tag\">ADHD</span>\r\n            <span class=\"help-area-tag\">Brak motywacji</span>\r\n            <span class=\"help-area-tag\">Brak satysfakcji z życia</span>\r\n            <span class=\"help-area-tag\">CHAD (choroba afektywna dwubiegunowa)</span>\r\n            <span class=\"help-area-tag\">Depresja</span>\r\n            <span class=\"help-area-tag\">Kryzys egzystencjalny</span>\r\n            <span class=\"help-area-tag\">LGBTQIA+</span>\r\n            <span class=\"help-area-tag\">Niska samoocena</span>\r\n            <span class=\"help-area-tag\">OCD (zaburzenia obsesyjno-kompulsyjne)</span>\r\n            <span class=\"help-area-tag\">Problem z samoakceptacją</span>\r\n            <span class=\"help-area-tag\">Problemy rodzicielskie</span>\r\n            <span class=\"help-area-tag\">Problemy rodzinne</span>\r\n            <span class=\"help-area-tag\">Problemy seksuologiczne</span>\r\n            <span class=\"help-area-tag\">Problemy tożsamościowe</span>\r\n            <span class=\"help-area-tag\">Problemy w pracy</span>\r\n            <span class=\"help-area-tag is-hidden\">Problemy w relacjach</span>\r\n            <span class=\"help-area-tag is-hidden\">Problemy z pamięcią/uwagą</span>\r\n            <span class=\"help-area-tag is-hidden\">Problemy zdrowotne</span>\r\n            <span class=\"help-area-tag is-hidden\">Problemy ze snem</span>\r\n            <span class=\"help-area-tag is-hidden\">Prokrastynacja</span>\r\n            <span class=\"help-area-tag is-hidden\">Rozstanie</span>\r\n            <span class=\"help-area-tag is-hidden\">Samotność</span>\r\n            <span class=\"help-area-tag is-hidden\">Smutek</span>\r\n            <span class=\"help-area-tag is-hidden\">Stres</span>\r\n            <span class=\"help-area-tag is-hidden\">Trauma</span>\r\n            <span class=\"help-area-tag is-hidden\">Utrata sensu życia</span>\r\n            <span class=\"help-area-tag is-hidden\">Wypalenie zawodowe</span>\r\n            <span class=\"help-area-tag is-hidden\">Zaburzenia lękowe</span>\r\n            <span class=\"help-area-tag is-hidden\">Zaburzenia odżywiania</span>\r\n            <span class=\"help-area-tag is-hidden\">Zaburzenia osobowości</span>\r\n                <button type=\"button\" class=\"help-area-tag more-tag\" data-show-more-tags>+15</button>\r\n    </div>\r\n\r\n            </div>\r\n\r\n                                    <h4>Podejście terapeutyczne</h4>\r\n            <div class=\"psy-nurty-row\">\r\n                <div class=\"product-currents-wrapper\">\r\n    <span class=\"product-currents__label\">Nurty: </span>\r\n                    <a href=\"http://localhost:8000/nurt/nurt-tsr/\" class=\"product-current__tag\">Nurt TSR</a>\r\n    </div>\r\n\r\n            </div>\r\n                    </div>\r\n\r\n        <section class=\"psy-booking-area\">\r\n            <div class=\"psy-calendar-wrapper\">\r\n                <div id=\"bookero_wrapper\" class=\"bookero-calendar-wrapper\" data-calendar-type=\"product\" data-id-pelno=\"31067\" data-id-nisko=\"31056\"><div class=\"bookero-preloader-wrapper\"></div></div><div id=\"bookero_render_target\"></div><div id=\"what_calendar\"></div>\r\n            </div>\r\n        </section>\r\n\r\n        <section class=\"psy-how-to-book\">\r\n            <h2>Jak zarezerwować wizytę?</h2>\r\n            <div class=\"psy-steps-container\">\r\n                <div class=\"psy-step-item\">\r\n                    <span class=\"psy-step-number\">1</span>\r\n                    <span class=\"psy-step-text\">Wybierz usługę, odpowiedni termin i godzinę</span>\r\n                </div>\r\n                <div class=\"psy-step-item\">\r\n                    <span class=\"psy-step-number\">2</span>\r\n                    <span class=\"psy-step-text\">Uzupełnij dane i opłać wizytę</span>\r\n                </div>\r\n                <div class=\"psy-step-item\">\r\n                    <span class=\"psy-step-number\">3</span>\r\n                    <span class=\"psy-step-text\">Jeśli zarezerwowałeś/aś termin online, link do spotkania znajduje się w wiadomości e-mail</span>\r\n      