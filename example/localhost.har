            "size": 45282,
            "mimeType": "application/json",
            "text": "{\"result\":1,\"require_mail\":1,\"require_phone\":1,\"people_required\":1,\"show_prices\":2,\"status\":0,\"auto_accept\":1,\"auto_email\":1,\"msg_sent\":\"Potwierdzamy dokonanie rezerwacji. \\nDzi\\u0119kujemy Fundacja Niepodzielni!\",\"msg_confirmed\":\"Potwierdzamy dokonanie rezerwacji.\",\"msg_payment\":\"Prosimy o dokonanie p\\u0142atno\\u015bci w ci\\u0105gu godziny od zarezerwowania miejsca w celu zatwierdzenia rezerwacji . P\\u0142atno\\u015bci mo\\u017cna dokona\\u0107 klikaj\\u0105c na przycisk poni\\u017cej.\",\"msg_denied\":\"Odrzucenie rezerwacji. Brak miejsc w tym terminie.\",\"msg_waiting_list\":\"Zosta\\u0142e\\u015b zapisany na list\\u0119 rezerwow\\u0105.\",\"msg_order_confirmed\":\"Potwierdzamy dokonanie zam\\u00f3wienia.\",\"msg_order_denied\":\"Odrzucenie zam\\u00f3wienia. Brak mo\\u017cliwo\\u015bci dokonania zakupu.\",\"msg_order_payment\":\"Prosimy o dokonanie p\\u0142atno\\u015bci w celu potwierdzenia zakupu. P\\u0142atno\\u015bci mo\\u017cna dokona\\u0107 klikaj\\u0105c na przycisk poni\\u017cej.\",\"msg_auto_payment\":\"Prosimy czeka\\u0107. Za chwil\\u0119 zostaniesz przekierowany do p\\u0142atno\\u015bci.\",\"auto_payment\":0,\"workers\":1,\"workers_list\":[{\"id\":27826,\"name\":\"Adam Radomski\",\"avatar\":null,\"avatar_color\":\"#b6d8e9\",\"avatar_initials\":\"AR\",\"description\":\"\"},{\"id\":24106,\"name\":\"Adrianna Garczy\\u0144ska\",\"avatar\":null,\"avatar_color\":\"#b6d8e9\",\"avatar_initials\":\"AG\",\"description\":\"\"},{\"id\":31885,\"name\":\"Adrianna Jo\\u0142kiewicz\",\"avatar\":null,\"avatar_color\":\"#b6d8e9\",\"avatar_initials\":\"AJ\",\"description\":\"\"},{\"id\":24109,\"name\":\"Agata Przybylska-Poszwa\",\"avatar\":\"https:\\/\\/cdn.bookero.pl\\/cache\\/200x200\\/e94ef1e0fcb3405251263f95d7a7f945_1733220715_2020-09-09-13-23-21-777.jpg\",\"avatar_color\":\"#73B4AE\",\"avatar_initials\":\"AP\",\"description\":\"\"},{\"id\":23046,\"name\":\"Aleksandra Bijak\",\"avatar\":null,\"avatar_color\":\"#b6