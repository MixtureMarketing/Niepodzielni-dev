# Bookero cron — uruchamia zaległe zadania WP co 5 minut (A9)
# flock -n: jeśli poprzednia instancja wciąż działa, pomiń — brak overlappingu i DB locków.
# Zmiana z */1 na */5: 5 psych./run + delay 0.3s = ryzyko overlap przy minutowym harmonogramie.
# Plik musi kończyć się nową linią (wymóg crona)
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
*/5 * * * * root /usr/bin/flock -n /tmp/wp-cron.lock /usr/local/bin/php /usr/local/bin/wp cron event run --due-now --path=/var/www/html/web/wp --url=http://localhost:8000 --allow-root >> /proc/1/fd/1 2>/proc/1/fd/2

